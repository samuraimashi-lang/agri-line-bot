# ===================================================
# 環境変数の設定例
# このファイルをコピーして .env という名前で保存し
# 各項目に実際の値を入力してください
# ===================================================

# LINE（必須）
LINE_CHANNEL_ACCESS_TOKEN=ここにLINEのアクセストークンを貼り付け
LINE_CHANNEL_SECRET=ここにLINEのチャンネルシークレットを貼り付け

# Claude AI（必須）
ANTHROPIC_API_KEY=ここにAnthropicのAPIキーを貼り付け

# OpenAI Whisper - 音声文字起こし用（必須）
OPENAI_API_KEY=ここにOpenAIのAPIキーを貼り付け

# 天気API（任意：なくても動きます）
WEATHER_API_KEY=ここにOpenWeatherMapのAPIキーを貼り付け

# Googleスプレッドシート名（任意：変更可）
SHEET_NAME=農作業記録
